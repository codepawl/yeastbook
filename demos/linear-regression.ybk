    {
      "id": "lr-08-predict",
      "type": "code",
      "source": "// Cell 8: Predict on new houses\nfunction predictPrice(\n  sqft: number,\n  bedrooms: number,\n  ageYears: number\n): number {\n  const input = [[\n    (sqft - mean[0]!) / std[0]!,\n    (bedrooms - mean[1]!) / std[1]!,\n    (ageYears - mean[2]!) / std[2]!,\n  ]]\n  return Math.round(model.predict(input)[0]!)\n}\n\nconst newHouses = [\n  { sqft: 1700, beds: 3, age: 7 },\n  { sqft: 3000, beds: 5, age: 1 },\n  { sqft: 700, beds: 1, age: 30 },\n]\n\nnewHouses.map(h => ({\n  ...h,\n  predictedPrice: `$${predictPrice(h.sqft, h.beds, h.age).toLocaleString()}`\n}))",
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "[\n  {\n    sqft: 1700,\n    beds: 3,\n    age: 7,\n    predictedPrice: \"$383,759\",\n  }, {\n    sqft: 3000,\n    beds: 5,\n    age: 1,\n    predictedPrice: \"$700,234\",\n  }, {\n    sqft: 700,\n    beds: 1,\n    age: 30,\n    predictedPrice: \"$132,469\",\n  }\n]"
          },
          "metadata": {},
          "execution_count": 8,
          "richOutput": {
