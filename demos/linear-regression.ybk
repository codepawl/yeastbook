  "cells": [
    {
      "id": "lr-header",
      "type": "markdown",
      "source": "# Linear Regression from Scratch\nTraining a linear regression model in pure TypeScript — no libraries needed.\n\nPredicts house prices from: square footage, bedrooms, and age."
    },
    {
      "id": "lr-01-dataset",
      "type": "code",
      "source": "// Cell 1: Setup dataset — predict house prices\nconst dataset = {\n  // [size_sqft, bedrooms, age_years] → price_usd\n  X: [\n    [1200, 2, 10], [1500, 3, 5], [900, 1, 20],\n    [2000, 4, 2], [1800, 3, 8], [1100, 2, 15],\n    [2500, 5, 1], [1300, 2, 12], [1600, 3, 6],\n    [800, 1, 25], [2200, 4, 3], [1400, 2, 9],\n  ],\n  y: [\n    250000, 350000, 180000, 480000, 420000, 220000,\n    580000, 270000, 370000, 160000, 510000, 290000,\n  ]\n}\n\nconsole.log(\"Dataset size:\", dataset.X.length, \"samples\")\nconsole.log(\"Features: size_sqft, bedrooms, age_years\")\nconsole.log(\"Target: price_usd\")\ndataset.X.slice(0, 3).map((x, i) => ({\n  features: x,\n  price: dataset.y[i]\n}))",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Dataset size: 12 samples\nFeatures: size_sqft, bedrooms, age_years\nTarget: price_usd\n"
          ]
        },
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "[\n  {\n    features: [ 1200, 2, 10 ],\n    price: 250000,\n  }, {\n    features: [ 1500, 3, 5 ],\n    price: 350000,\n  }, {\n    features: [ 900, 1, 20 ],\n    price: 180000,\n  }\n]"
          },
          "metadata": {},
          "execution_count": 1,
          "richOutput": {
            "type": "table",
            "rows": [
              {
                "features": [
                  1200,
                  2,
                  10
